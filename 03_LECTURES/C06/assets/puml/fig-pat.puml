@startuml fig-pat
skinparam backgroundColor white
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam shadowing false
skinparam roundcorner 12

title PAT (NAT Overload): IP + Port Rewriting

package "Private LAN" as lan #FFF3E0 {
    rectangle "Host A\n192.168.0.11:51000" as A #FFE0B2
    rectangle "Host B\n192.168.0.12:51001" as B #FFE0B2
}

rectangle "PAT Router\nWAN: 203.0.113.5" as R #E3F2FD

cloud "Internet" as inet #F5F5F5 {
    rectangle "Server\n198.51.100.20:80" as S #C8E6C9
}

A --> R : src .11:51000
B --> R : src .12:51001

R --> S : all from 203.0.113.5

rectangle "PAT Translation Table" as TBL #FFF9C4 {
    rectangle "192.168.0.11:51000 ↔ 203.0.113.5:62001\n192.168.0.12:51001 ↔ 203.0.113.5:62002" as entries #FFF9C4
}

legend right
  PAT maps many private hosts to a
  single public IP by distinguishing
  flows via unique port numbers.
  This is the most common form of
  NAT in home and office networks.
endlegend
@enduml
