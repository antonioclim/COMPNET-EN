{
  "project": "S19",
  "pcap_relpath": "artifacts/pcap/traffic_e2.pcap",
  "decode_as": [],
  "rules": [
    {
      "id": "R1",
      "filter": "tcp.dstport==5019 && tcp.flags.syn==1 && tcp.flags.ack==0",
      "condition": ">= 1",
      "description": "Handshake to the auction service."
    },
    {
      "id": "R2",
      "filter": "tcp.port==5019 && (frame contains \"SELL\" || frame contains \"OPEN\")",
      "condition": ">= 1",
      "description": "Auction creation or open-state announcement is visible."
    },
    {
      "id": "R3",
      "filter": "tcp.port==5019 && frame contains \"BID\"",
      "condition": ">= 2",
      "description": "At least two bids are visible in payload."
    },
    {
      "id": "R4",
      "filter": "tcp.port==5019 && (frame contains \"OUTBID\" || frame contains \"TOP_BID\")",
      "condition": ">= 1",
      "description": "Competitive update to the highest bid is visible."
    },
    {
      "id": "R5",
      "filter": "tcp.port==5019 && (frame contains \"CLOSED\" || frame contains \"WINNER\")",
      "condition": ">= 1",
      "description": "Automatic closure and winner reporting are observable."
    }
  ]
}
