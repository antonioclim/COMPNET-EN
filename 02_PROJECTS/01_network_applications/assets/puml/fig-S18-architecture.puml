@startuml fig-S18-architecture
skinparam backgroundColor white
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam shadowing false
skinparam roundcorner 12

title S18 — Resource Reservation: Holds, Confirmation and Timers

package "Docker Network" as net #F5F5F5 {

    rectangle "client_a" as cA #E3F2FD
    rectangle "client_b" as cB #E3F2FD
    rectangle "watcher_client" as cW #E3F2FD

    rectangle "reservation_service\n:5018/TCP" as srv #C8E6C9 {
        rectangle "Session Manager" as sess #A5D6A7
        rectangle "Availability Index" as idx #FFF9C4
        rectangle "Hold Timer Manager" as timers #FFCDD2
        rectangle "Reservation Store" as store #BBDEFB
        rectangle "Notification Fan-out" as notif #E1BEE7
    }

    rectangle "tester\n(pytest -m e2)" as tester #FFF9C4
}

cA --> srv : "LIST, HOLD, CONFIRM"
cB --> srv : "LIST, HOLD, MODIFY, DELETE"
cW --> srv : "WATCH resource"
tester -up-> srv : runs competing requests\ncaptures overlap refusal

sess --> idx
sess --> timers
sess --> store
sess --> notif

legend right
  Server time is authoritative
  Holds expire unless confirmed
  Overlaps are refused deterministically
  Notifications expose state changes
  Port: 5018/TCP
endlegend
@enduml
