@startuml fig-flsm-equal-split
skinparam backgroundColor white
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam shadowing false
skinparam roundcorner 12

title Fixed-Length Subnetting (FLSM): Splitting /24 into 4 Equal Subnets

rectangle "Original Block\n192.168.10.0/24\n(256 addresses)" as orig #E3F2FD

rectangle "Borrow 2 bits → new prefix /26\nEach subnet: 64 addresses (62 usable)" as calc #FFF9C4

package "4 Equal Subnets (/26)" as subs #E8F5E9 {
    rectangle "Subnet 0\n192.168.10.0/26\nHosts: .1 – .62\nBroadcast: .63" as s0 #C8E6C9
    rectangle "Subnet 1\n192.168.10.64/26\nHosts: .65 – .126\nBroadcast: .127" as s1 #C8E6C9
    rectangle "Subnet 2\n192.168.10.128/26\nHosts: .129 – .190\nBroadcast: .191" as s2 #C8E6C9
    rectangle "Subnet 3\n192.168.10.192/26\nHosts: .193 – .254\nBroadcast: .255" as s3 #C8E6C9
}

orig -[#1565C0]down-> calc : borrow bits
calc -[#43A047]down-> subs : divide equally

s0 -[hidden]right-> s1
s1 -[hidden]right-> s2
s2 -[hidden]right-> s3

legend bottom
  N subnets require ceiling(log2 N) borrowed bits.
  4 subnets = 2 bits borrowed → /24 becomes /26.
  Subnet increment = 2^(32 − new prefix) = 64.
  All subnets are the same size (no waste optimisation).
endlegend
@enduml
